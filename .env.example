# GitHub Personal Access Token
# Get yours at: https://github.com/settings/tokens
# Required scopes: read:user
GITHUB_TOKEN=your_github_token_here

# Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Supabase Configuration
# The server-side CMS/admin storage now requires a real service role key.
# After setting these vars, run supabase/cms-schema.sql in the Supabase SQL editor.
VITE_SUPABASE_URL=https://grjltcbjxiocekfnjhgz.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI (for your chatbot)
OPENAI_API_KEY=your_openai_api_key_here
