# Local dev server port
PORT=5001

# Primary database used by the Express API.
# Copy the latest Postgres connection string from Supabase or your current host.
# If Supabase gives you both direct and pooler URLs, prefer the one your environment can resolve.
DATABASE_URL=postgresql://postgres:your_db_password@db.your-project-ref.supabase.co:5432/postgres

# Gemini API key used by the portfolio chat endpoint.
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase project settings used by the frontend and admin-related server tasks.
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Contact form email delivery via Brevo SMTP.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_smtp_user
BREVO_SMTP_PASS=your_brevo_smtp_password
BREVO_FROM_EMAIL=your-sender@example.com
BREVO_FROM_NAME=Klein Portfolio
NOTIFY_EMAIL=your-notify-email@example.com

# Admin CMS password. Required in production.
ADMIN_PASSWORD=change_this_before_deploy
